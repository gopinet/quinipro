---
import Layout from '@/layouts/Layout.astro';
import { getFixtures, getPredictions } from '@/lib/db';
import { leaderboard, pointsFor } from '@/lib/scoring';
import { DEFAULT_LEAGUE, DEFAULT_SEASON } from 'astro:env/server';
import type { Fixture, Prediction } from '@/lib/types';

export const prerender = false;

const league = Number(Astro.url.searchParams.get('league') ?? DEFAULT_LEAGUE);
const season = Number(Astro.url.searchParams.get('season') ?? DEFAULT_SEASON);

let fixtures: Fixture[] = [];
let predictions: Prediction[] = [];
let loadError: string | null = null;

try {
  [fixtures, predictions] = await Promise.all([getFixtures(league, season), getPredictions()]);
} catch (e) {
  loadError = (e as Error).message;
}

const byId = new Map(fixtures.map((f) => [f.id, f]));
const myPredByFixture = new Map<number, Prediction>();
const aiPredByFixture = new Map<number, Prediction>();
for (const p of predictions) {
  if (p.source === 'me') myPredByFixture.set(p.fixture_id, p);
  if (p.source === 'ai') aiPredByFixture.set(p.fixture_id, p);
}

const [ai, me] = leaderboard(predictions, byId);

const fmtDate = (iso: string) =>
  new Intl.DateTimeFormat('es', { day: 'numeric', month: 'short' }).format(new Date(iso));
const fmtTime = (iso: string) =>
  new Intl.DateTimeFormat('es', { hour: '2-digit', minute: '2-digit' }).format(new Date(iso));
const abbrev = (name: string) =>
  name.split(/\s+/).filter(w => !['del','de','la','el','y','e','of','the'].includes(w.toLowerCase()))[0]?.slice(0, 3).toUpperCase() ?? '?';
---

<Layout>
  <section class="scoreboard">
    <div class="side ai">
      <div class="label">IA</div>
      <div class="pts">{ai.points}</div>
      <div class="detail">{ai.exact} exactos · {ai.results} resultados · {ai.graded} jugados</div>
    </div>
    <div class="vs">vs</div>
    <div class="side me">
      <div class="label">Yo</div>
      <div class="pts">{me.points}</div>
      <div class="detail">{me.exact} exactos · {me.results} resultados · {me.graded} jugados</div>
    </div>
  </section>

  <div class="toolbar">
    <button id="refresh">Refrescar partidos</button>
    <button id="sync">Sincronizar resultados</button>
  </div>

  {loadError && <p class="msg err">Error cargando datos: {loadError}</p>}

  {fixtures.length === 0 && !loadError && (
    <p class="empty">No hay partidos en caché. Pulsa "Refrescar partidos" para traerlos.</p>
  )}

  {fixtures.map((f) => {
    const myPred = myPredByFixture.get(f.id) ?? null;
    const hasAi  = aiPredByFixture.has(f.id);
    const played  = f.final_home !== null && f.final_away !== null;
    const started = new Date() >= new Date(f.kickoff);
    const pts   = myPred ? pointsFor(myPred, f) : null;
    const badge = pts === 3 ? 'exacto' : pts === 1 ? 'resultado' : null;
    return (
      <a class="fc-card" href={`/fixture/${f.id}`}>
        <div class="fc-top">
          <span class="fc-date">{fmtDate(f.kickoff)} · {fmtTime(f.kickoff)}</span>
          <div class="fc-top-right">
            {hasAi && <span class="fc-badge-sm ai">IA ✓</span>}
            {played && <span class="fc-badge-sm ft">Final</span>}
            {!played && started && <span class="fc-badge-sm live">En juego</span>}
          </div>
        </div>
        <div class="fc-match">
          <div class="fc-team">
            {f.home_logo
              ? <img class="fc-flag" src={f.home_logo} alt="" />
              : <div class="fc-flag-ph" />}
            <span class="fc-code">{abbrev(f.home_team)}</span>
            <span class="fc-name">{f.home_team}</span>
            {played && <span class="fc-score">{f.final_home}</span>}
          </div>
          <span class="fc-vs">vs</span>
          <div class="fc-team">
            {f.away_logo
              ? <img class="fc-flag" src={f.away_logo} alt="" />
              : <div class="fc-flag-ph" />}
            <span class="fc-code">{abbrev(f.away_team)}</span>
            <span class="fc-name">{f.away_team}</span>
            {played && <span class="fc-score">{f.final_away}</span>}
          </div>
        </div>
        <div class="fc-pred">
          <span class="fc-pred-label">Tu Predicción</span>
          {myPred ? (
            <div class="fc-pred-right">
              <span class="fc-pred-score">{myPred.pred_home} – {myPred.pred_away}</span>
              {badge === 'exacto'    && <span class="fc-badge exact">✓ Exacto</span>}
              {badge === 'resultado' && <span class="fc-badge result">✓ Resultado</span>}
            </div>
          ) : started ? (
            <span class="fc-pred-empty">—</span>
          ) : (
            <span class="fc-pred-empty">Sin predicción</span>
          )}
        </div>
      </a>
    );
  })}
</Layout>

<script define:vars={{ league, season }}>
  const run = async (btn, url) => {
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = '…';
    try {
      const res = await fetch(url);
      const data = await res.json();
      if (!data.ok) throw new Error(data.error);
      location.reload();
    } catch (e) {
      btn.textContent = 'Error';
      console.error(e);
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 1500);
    }
  };
  document.getElementById('refresh')?.addEventListener('click', (e) =>
    run(e.target, `/api/fixtures?league=${league}&season=${season}&refresh=1`));
  document.getElementById('sync')?.addEventListener('click', (e) =>
    run(e.target, `/api/sync-results?league=${league}&season=${season}`));
</script>

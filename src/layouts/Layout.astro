---
import '@/styles/global.css';
interface Props { title?: string; }
const { title = 'quinipro' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <h1>quini<b>pro</b></h1>
        <span class="sub">IA vs Yo · pronósticos</span>
      </header>
      <slot />
    </div>
    <script>
      document.querySelectorAll('time.local-time').forEach(el => {
        const iso = el.getAttribute('datetime');
        if (!iso) return;
        const d = new Date(iso);
        const long = (el as HTMLElement).dataset.fmt === 'long';
        const date = new Intl.DateTimeFormat('es', long
          ? { weekday: 'long', day: 'numeric', month: 'long' }
          : { day: 'numeric', month: 'short' }).format(d);
        const time = new Intl.DateTimeFormat('es', { hour: '2-digit', minute: '2-digit' }).format(d);
        el.textContent = `${date} · ${time}`;
      });
    </script>
  </body>
</html>

# --- api-sports.io (football) ---
FOOTBALL_API_KEY=your_apisports_key

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
# service_role key. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_KEY=your_service_role_key

# --- OpenAI ---
OPENAI_API_KEY=your_openai_key
# Model is configurable so you can swap without touching code.
OPENAI_MODEL=gpt-4o-mini

# --- App defaults (optional) ---
# Default league/season used by the homepage if no query params are given.
# 1 = FIFA World Cup. 39 = Premier League. See api-sports docs for league IDs.
DEFAULT_LEAGUE=1
DEFAULT_SEASON=2026
